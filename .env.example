PORT=3000

# JWT
JWT_SECRET=change_this_to_a_long_random_secret

# SQLite DB path
# Local: ./data/boutique.db
# Render disk: /var/data/boutique.db
DB_PATH=./data/boutique.db

# Uploaded product images
# Local: ./uploads
# Render disk: /var/data/uploads
UPLOADS_DIR=./uploads

# Nodemailer (e.g. Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# Public app URL (used in emails and M-Pesa callbacks)
BASE_URL=http://localhost:3000

# M-Pesa
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/mpesa-callback
